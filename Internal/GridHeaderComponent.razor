@using DataJuggler.Excelerate
@using System.Drawing
@using BlazorStyled

<Styled @bind-Classname=@FilterRowStyle>
    width: @WidthStyle;
    
</Styled>

<table class="tablelayoutfixed bordercollapse">
    @if (GridColumns != null)
    {
        @GridColumns(this.ParentGrid)
    }
    @if (HasColumns)
    {
        <colgroup>
            @foreach (Column column in Columns)
            {
                <col class="@column.ClassName" />
            }
        </colgroup>
    }
    <thead>
        <tr class="@ColumnHeaderStyle @ColumnHeaderClassName @StickyStyle">
            @foreach (Column column in Columns)
            {
                <th class="@column.ClassName">@column.Caption</th>
            }            
        </tr>
    </thead>
    @if (ShowFilterRow)
    {
        <tr class="@FilterRowStyle displayinline textdonotwrap">            
            @foreach (Column column in Columns)
            {
                <td class="displayinline textdonotwrap">
                    <TextBoxComponent Name="@column.ColumnName" Caption="" Parent="this"
                        Height="24" LabelClassName="down3" Column1Width="0" Column2Width="@column.Width"
                        Display="inline" ClassName="displayinline"
                        Width="@column.Width" TextBoxWidth="@column.Width" TextBoxBackColor="@Color.LightSteelBlue">
                    </TextBoxComponent>
                </td>   
            }
        </tr>
    }
</table>        